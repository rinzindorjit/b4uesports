{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/test.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/test",
      "dest": "/api/test.js"
    },
    {
      "src": "/api/pi/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/metadata",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/auth/pi",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/profile",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}