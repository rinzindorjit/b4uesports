{
  "version": 2,
  "builds": [
    {
      "src": "api/pi/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/metadata.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/pi/auth",
      "dest": "/api/pi/auth.js"
    },
    {
      "src": "/api/pi/payments",
      "dest": "/api/pi/payments.js"
    },
    {
      "src": "/api/pi/user",
      "dest": "/api/pi/user.js"
    },
    {
      "src": "/api/pi/webhook",
      "dest": "/api/pi/webhook.js"
    },
    {
      "src": "/api/metadata",
      "dest": "/api/metadata.js"
    }
  ]
}