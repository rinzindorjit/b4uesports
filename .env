// EmailJS Configuration
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_ADMIN_TEMPLATE_ID=your_admin_template_id
EMAILJS_PUBLIC_KEY=your_public_key
ADMIN_EMAIL=admin@b4uesports.com

// SendGrid (deprecated - using EmailJS now)
// SENDGRID_API_KEY=your_sendgrid_api_key
// SENDGRID_FROM_EMAIL=noreply@b4uesports.com

// Pi Network
// For sandbox/testnet mode, use PI_SECRET_KEY
PI_SECRET_KEY=your_actual_pi_secret_key_here
PI_SERVER_API_KEY=your_actual_pi_server_api_key_here
PI_APP_ID=your_actual_app_id_here

// For Pi Testnet verification, make sure to set the actual values above
// You can get these from the Pi Developer Portal

// Database
DATABASE_URL=your_database_url

// JWT
JWT_SECRET=your_jwt_secret

// CoinGecko API
COINGECKO_API_KEY=your_coingecko_api_key

// Other
NODE_ENV=development